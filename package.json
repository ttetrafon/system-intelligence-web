{
  "version": "0.1.17",
  "name": "system-intelligence-web",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "react-router dev --host",
    "preview": "pnpm run build && vite preview",
    "postinstall": "npm run typecheck",
    "build:staging": "react-router build --mode staging",
    "build:production": "react-router build --mode production",
    "cf-typegen": "wrangler types",
    "typecheck": "npm run cf-typegen && react-router typegen && tsc -b",
    "db:migrate:staging": "wrangler d1 migrations apply system-intelligence-db-staging --remote",
    "db:migrate:production": "wrangler d1 migrations apply system-intelligence-db-production --remote",
    "deploy:staging": "pnpm run build:staging && wrangler deploy",
    "deploy:production": "pnpm run build:production && wrangler deploy"
  },
  "dependencies": {
    "bcryptjs": "3.0.3",
    "isbot": "5.1.39",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-router": "7.14.2",
    "react-router-dom": "7.14.2"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.34.0",
    "@react-router/dev": "7.14.2",
    "@tailwindcss/vite": "4.2.4",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "tailwindcss": "4.2.4",
    "typescript": "6.0.3",
    "vite": "8.0.10",
    "wrangler": "4.86.0"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  }
}