{
	"name": "system-intelligence-web",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "react-router dev --host",
		"preview": "pnpm run build && vite preview",
		"cf-typegen": "wrangler types",
		"typecheck": "npm run cf-typegen && react-router typegen && tsc -b",
		"postinstall": "npm run typecheck",
		"build:staging": "react-router build --mode staging",
		"build:production": "react-router build --mode production",
		"deploy:staging": "pnpm run build:staging && wrangler deploy",
		"deploy:production": "pnpm run build:production && wrangler deploy"
	},
	"packageManager": "pnpm@10.26.2",
	"dependencies": {
		"isbot": "^5.1.32",
		"react": "^19.2.3",
		"react-dom": "^19.2.3",
		"react-router": "^7.11.0",
		"react-router-dom": "^7.11.0"
	},
	"devDependencies": {
		"@cloudflare/vite-plugin": "^1.19.0",
		"@react-router/dev": "^7.11.0",
		"@tailwindcss/vite": "^4.1.18",
		"@types/node": "^25.0.3",
		"@types/react": "^19.2.7",
		"@types/react-dom": "^19.2.3",
		"tailwindcss": "^4.1.18",
		"typescript": "^5.9.3",
		"vite": "^7.3.0",
		"vite-plugin-icons-spritesheet": "^3.0.1",
		"vite-tsconfig-paths": "^6.0.3",
		"wrangler": "^4.56.0"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"supabase"
		]
	}
}