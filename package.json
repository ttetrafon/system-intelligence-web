{
  "version": "0.1.27",
  "name": "system-intelligence-web",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "dependencies": {
    "argon2": "0.44.0",
    "bcryptjs": "3.0.3",
    "isbot": "5.1.44",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router": "7.18.0",
    "react-router-dom": "7.18.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.42.1",
    "@react-router/dev": "7.15.1",
    "@tailwindcss/vite": "4.3.1",
    "@types/node": "26.0.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "tailwindcss": "4.3.1",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "wrangler": "4.103.0"
  },
  "scripts": {
    "dev": "react-router dev --host",
    "preview": "pnpm run build && vite preview",
    "postinstall": "npm run typecheck",
    "build:staging": "react-router build --mode staging",
    "build:production": "react-router build --mode production",
    "cf-typegen": "wrangler types",
    "typecheck": "npm run cf-typegen && react-router typegen && tsc -b",
    "db:migrate:staging": "wrangler d1 migrations/staging apply system-intelligence-db-staging --remote",
    "db:migrate:production": "wrangler d1 migrations/production apply system-intelligence-db-production --remote",
    "deploy:staging": "pnpm run build:staging && wrangler deploy",
    "deploy:production": "pnpm run build:production && wrangler deploy"
  }
}