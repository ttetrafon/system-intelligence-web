/**
 * For more details on how to configure Wrangler, refer to:
 * https://developers.cloudflare.com/workers/wrangler/configuration/
 */
{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "system-intelligence-web",
	"compatibility_flags": [
		"nodejs_compat",
	],
	"compatibility_date": "2025-07-09",
	"main": "./workers/app.ts",
	"env": {
		"staging": {
			"vars": {
				"PUBLIC_ENVIRONMENT": "staging"
			},
			"kv_namespaces": [
				{
					"binding": "AUTH_KV",
					"id": "c45a7adfa4d94e7680f941602af79a32",
				}
			],
			"d1_databases": [
				{
					"binding": "DB",
					"database_name": "system-intelligence-db-staging",
					"database_id": "2db72910-3263-4be7-be7d-8cd77b3dbe73",
				}
			],
			"r2_buckets": [
				{
					"bucket_name": "system-intelligence-assets-staging",
					"binding": "ASSETS",
					"jurisdiction": "eu",
				}
			]
		},
		"production": {
			"vars": {
				"PUBLIC_ENVIRONMENT": "production"
			},
			"kv_namespaces": [
				{
					"binding": "AUTH_KV",
					"id": "af3d4e4455b74785bf89d4c64c5629a6",
				}
			],
			"d1_databases": [
				{
					"binding": "DB",
					"database_name": "system-intelligence-db-production",
					"database_id": "f0be761e-6535-4450-bc28-9a0694f8501e"
				}
			],
			"r2_buckets": [
				{
					"bucket_name": "system-intelligence-assets-production",
					"binding": "ASSETS",
					"jurisdiction": "eu",
				}
			]
		}
	},
	"vars": {
		"PUBLIC_ENVIRONMENT": "development"
	},
	"kv_namespaces": [
		{
			"binding": "AUTH_KV",
			"id": "c45a7adfa4d94e7680f941602af79a32",
			"remote": true
		}
	],
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "system-intelligence-db-staging",
			"database_id": "2db72910-3263-4be7-be7d-8cd77b3dbe73",
			"remote": true,
		}
	],
	"r2_buckets": [
		{
			"bucket_name": "system-intelligence-assets-staging",
			"binding": "ASSETS",
			"remote": true,
			"jurisdiction": "eu",
		}
	],
	"observability": {
		"enabled": true
	},
}